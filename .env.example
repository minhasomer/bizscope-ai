# Environment variables for BizScope AI

# Google Gemini API key (Required if VITE_DEMO_MODE=false)
GEMINI_API_KEY=

# Set to true to bypass Gemini API and use offline high-fidelity mock reports
VITE_DEMO_MODE=true

# Supabase Auth configurations
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe (backend-only — never expose secret key to the frontend) ──────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# For local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring Price IDs from your Stripe product catalogue
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PRO_PLUS=price_...

# Canonical app URL used in Stripe redirect URLs (no trailing slash)
# For local dev: http://localhost:3000
# For Vercel: set to your production domain, e.g. https://bizscope.example.com
APP_URL=http://localhost:3000

# Canonical public URL of the app — used as Supabase OAuth redirectTo.
# Set this in Vercel's Environment Variables to your production domain and add
# it to Supabase Dashboard → Authentication → URL Configuration → Allowed Redirect URLs.
# Falls back to window.location.origin when not set (fine for local dev).
VITE_APP_URL=http://localhost:3000
